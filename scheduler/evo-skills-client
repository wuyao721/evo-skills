def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print_usage()
        sys.exit(0)

    command = args[0]

    if command == "status":
        if len(args) >= 2 and not args[1].startswith("-"):
            agent_arg = args[1]
            full_flag = "--full" in args
            # 检查是否有数字参数 (status xxx N)
            n_arg = None
            for a in args[2:]:
                if a.isdigit():
                    n_arg = int(a)
                    break
            cmd_status_agent(agent_arg, n=n_arg, full=full_flag)
        else:
            cmd_status()

    elif command == "history":
        if len(args) < 2:
            print("【错误】请指定角色名称。用法：evo-skills-client history <agent>")
            sys.exit(1)
        cmd_history(args[1])

    elif command == "detail":
        if len(args) < 3:
            print("【错误】请指定角色名称和时间。用法：evo-skills-client detail <agent> <time>")
            sys.exit(1)
        cmd_detail(args[1], args[2])

    elif command == "config":
        if len(args) < 2:
            print("【错误】请指定角色名称。用法：evo-skills-client config <agent>")
            sys.exit(1)
        agent = args[1]

        if "--add" in args:
            # config <agent> --add <command> --cron <expr> --description <desc>
            #   [--executor <exec>] [--model <model>]
            add_idx = args.index("--add")
            if add_idx + 1 >= len(args):
                print("【错误】--add 后需要指定命令名。")
                sys.exit(1)
            add_cmd = args[add_idx + 1]
            cron_expr = ""
            desc = ""
            exec_val = ""
            model_val = ""
            if "--cron" in args:
                ci = args.index("--cron")
                cron_expr = args[ci + 1] if ci + 1 < len(args) else ""
            if "--description" in args:
                di = args.index("--description")
                desc = args[di + 1] if di + 1 < len(args) else ""
            if "--executor" in args:
                ei = args.index("--executor")
                exec_val = args[ei + 1] if ei + 1 < len(args) else ""
            if "--model" in args:
                mi = args.index("--model")
                model_val = args[mi + 1] if mi + 1 < len(args) else ""
            if not cron_expr:
                print("【错误】--add 需要 --cron 参数。")
                sys.exit(1)
            cmd_config_add(agent, add_cmd, cron_expr, desc or add_cmd,
                           exec_val, model_val)

        elif "--remove" in args:
            rm_idx = args.index("--remove")
            if rm_idx + 1 >= len(args):
                print("【错误】--remove 后需要指定命令名。")
                sys.exit(1)
            cmd_config_remove(agent, args[rm_idx + 1])

        elif "--set" in args:
            set_idx = args.index("--set")
            if set_idx + 1 < len(args):
                set_expr = args[set_idx + 1]
            else:
                print("【错误】--set 后需要指定表达式。")
                sys.exit(1)
            cmd_config(agent, set_expr)

        else:
            cmd_config(agent)

    else:
        print(f"【错误】未知命令：{command}")
        print()
        print_usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
