def _load_all_configs() -> dict:
    """加载 configs/ 下所有 .yaml 配置，返回 {agent_name: config_dict}。"""
    result = {}
    if not CONFIGS_DIR.exists():
        return result
    for f in sorted(CONFIGS_DIR.iterdir()):
        if f.suffix in (".yaml", ".yml"):
            try:
                cfg = load_yaml_file(f)
                name = f.stem
                if isinstance(cfg.get("agent"), dict):
                    name = cfg["agent"].get("name", f.stem)
                result[name] = cfg
            except Exception as e:
                print(f"  警告：解析 {f.name} 失败：{e}", file=sys.stderr)
    return result


